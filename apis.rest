Authorization: Bearer {{adminToken}}

### Admin: single order details
GET {{api}}/admin/orders/1
Authorization: Bearer {{adminToken}}

### Admin: update normal order status/payment/shipping
# orderStatus: processing | shipped | delivered | cancelled | returns
# paymentStatus: unpaid | paid | partial | refunded
PATCH {{api}}/admin/orders/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "orderStatus": "shipped",
  "paymentStatus": "paid",
  "paymentMode": "COD",
  "transactionId": "",
  "courierName": "Local Delivery",
  "cnNumber": "CN123456",
  "cnDate": "2026-06-07",
  "remark": "Order shipped from warehouse"
}

### Admin: combo order list
GET {{api}}/admin/combo-orders
Authorization: Bearer {{adminToken}}

### Admin: single combo order details
GET {{api}}/admin/combo-orders/1
Authorization: Bearer {{adminToken}}

### Admin: update combo order status/payment
PATCH {{api}}/admin/combo-orders/1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "orderStatus": "SHIPPED",
  "paymentStatus": "PAID",
  "remark": "Combo order shipped"
}

### Admin: OMS failed/pending order sync logs
GET {{api}}/admin/oms-order-syncs
Authorization: Bearer {{adminToken}}


