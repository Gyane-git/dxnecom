# ============================================================
# 6) CHECKOUT + ORDER APIs
# ============================================================

### Place COD order for normal product/cart checkout
# IMPORTANT: address is required. Do not send hardcoded address from mobile.
# id = productId, qty = selected quantity, unitPrice = selling price, total = unitPrice * qty
POST {{api}}/orders/cod
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "paymentMethod": "COD",
  "deliveryCharge": 100,
  "address": {
    "fullName": "Ram Sharma",
    "phone": "9800000000",
    "address": "New Road, Ward 22, Kathmandu",
    "city": "Kathmandu Metropolitan City",
    "region": "Bagmati",
    "area": "New Road"
  },
  "items": [
    {
      "id": 1,
      "qty": 2,
      "unitPrice": 150,
      "total": 300,
      "name": "Red Chilli Powder (R 100gm)"
    }
  ]
}

### Place COD order for combo checkout through same checkout flow
POST {{api}}/orders/cod
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "paymentMethod": "COD",
  "deliveryCharge": 100,
  "address": {
    "fullName": "Ram Sharma",
    "phone": "9800000000",
    "address": "New Road, Ward 22, Kathmandu",
    "city": "Kathmandu Metropolitan City",
    "region": "Bagmati",
    "area": "New Road"
  },
  "items": [
    {
      "type": "combo",
      "comboProductId": 2,
      "id": 2,
      "qty": 1,
      "unitPrice": 999,
      "total": 999,
      "name": "Family Combo Pack"
    }
  ]
}

### Get my normal orders / order history
GET {{api}}/orders
Authorization: Bearer {{userToken}}

### Get my combo orders / combo order history
GET {{api}}/combo-orders
Authorization: Bearer {{userToken}}

### Direct combo order create without checkout page
# Prefer /orders/cod for full checkout flow. This API creates combo order directly.
POST {{api}}/combo-orders
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "comboProductId": 2,
  "qty": 1
}

