  },
  "items": [
    {
      "id": 1,
      "qty": 2,
      "unitPrice": 150,
      "total": 300,
      "name": "Red Chilli Powder (R 100gm)"
    }
  ]
}

### ConnectIPS validation callback / manual validate
# Usually browser/payment gateway callback handles this. Keep for backend testing only.
POST {{baseUrl}}/connectips/validate
Content-Type: application/json

{
  "TXNID": "CONNECTIPS_TXN_ID",
  "TOKEN": "CONNECTIPS_TOKEN"
}

