# ============================================================
# NITYAGRO API HANDOFF FOR MOBILE APP
# ============================================================
# Usage:
# 1. For local testing keep @baseUrl = http://localhost:3000
# 2. For live testing change @baseUrl = https://nityagro.globaltech.com.np
# 3. Login API returns data.token. Mobile app should store that token securely.
# 4. Send auth token as: Authorization: Bearer {{userToken}}
# 5. Admin APIs need admin login token as: Authorization: Bearer {{adminToken}}
# 6. IDs returned by APIs are usually strings because DB uses BigInt.

@baseUrl = http://localhost:3000
@liveUrl = https://nityagro.globaltech.com.np
@api = {{baseUrl}}/api
@userToken = paste_user_login_token_here
@adminToken = paste_admin_login_token_here

# ============================================================
# 1) AUTH APIs
# ============================================================

### Signup Step 1: Send OTP to email
POST {{api}}/auth/signup/send-otp
Content-Type: application/json

{
  "name": "Ram Sharma",
  "phone": "9800000000",
  "email": "ram@example.com",
  "password": "Password@123"
}

### Signup Step 2: Verify OTP and create user
POST {{api}}/auth/signup/verify
Content-Type: application/json

{
  "name": "Ram Sharma",
  "phone": "9800000000",
  "email": "ram@example.com",
  "password": "Password@123",
  "otp": "123456"
}

### Login: user/admin role wise redirect data returns
POST {{api}}/auth/login
Content-Type: application/json

{
  "email": "ram@example.com",
  "password": "Password@123"
}

### Get logged-in user profile from token/cookie
GET {{api}}/auth/me
Authorization: Bearer {{userToken}}

### Logout logged-in user
POST {{api}}/auth/logout
Authorization: Bearer {{userToken}}

{}

### Forgot password: send reset OTP
POST {{api}}/auth/forgot-password
Content-Type: application/json

{
  "email": "ram@example.com"
}

### Verify reset OTP: creates reset session cookie
POST {{api}}/auth/verify-reset-otp
Content-Type: application/json

{
  "email": "ram@example.com",
  "otp": "123456"
}

### Reset password after OTP verification
POST {{api}}/auth/reset-password
Content-Type: application/json

{
  "email": "ram@example.com",
  "password": "NewPassword@123"
}

### Google login start URL
# Open this URL in browser/webview. Callback redirects based on login result.
GET {{api}}/auth/google


