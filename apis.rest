  "addType": "Home",
  "zipCode": "44600"
}

### Update address
PUT {{api}}/account/addresses
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "id": 1,
  "fullName": "Ram Sharma",
  "phone": "9800000000",
  "email": "ram@example.com",
  "region": "Bagmati",
  "district": "Kathmandu",
  "city": "Kathmandu Metropolitan City",
